# Package manager caches
.yarn/
.pnpm-store/
.npm/

# Compiled assets
*.min.js
*.min.css
*.bundle.js
*.bundle.css

# Lock files (already in your package.json workflow)
package-lock.json
yarn.lock
pnpm-lock.yaml
